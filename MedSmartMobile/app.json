{
  "expo": {
    "name": "MedSmart",
    "slug": "medsmart-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "medsmart",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0F4F8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medsmart.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F0F4F8"
      },
      "package": "com.medsmart.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Healy a besoin d'accéder à votre caméra pour scanner les QR codes des ordonnances."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Healy a besoin d'accéder à votre galerie pour télécharger vos documents d'identité et fichiers professionnels.",
          "cameraPermission": "Healy a besoin d'accéder à votre caméra pour photographier vos documents."
        }
      ],
      "expo-document-picker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F0F4F8",
          "image": "./assets/splash.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}